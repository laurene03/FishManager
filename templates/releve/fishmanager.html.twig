    <script>
        const app = {
            data: {
                readings: []
            },
            init: function() {
                // Load data
                const stored = localStorage.getItem('fishManagerData');
                if (stored) {
                    this.data.readings = JSON.parse(stored);
                } else {
                    // Default dummy data if empty
                    this.data.readings = [
                        { date: '2025-11-01', ph: 7.0, temp: 24.5 },
                        { date: '2025-11-05', ph: 7.2, temp: 25.0 }
                    ];
                }

                // Event Listeners
                // Event Listeners
                // Removed manual form submission listener as it is now handled by Symfony form


                // Set default date to today
                // Set default date to today - logic removed as it should be handled by form default or JS on the new input ID if needed
                // But Symfony DateType usually handles values. If we want default today in JS:
                // document.getElementById('releve_date').valueAsDate = new Date(); // ID auto-generated by Symfony usually `releve_date`
                
                // Add event listeners for navigation logic (Home/Relevé is handled directly in HTML)
                document.getElementById('nav-btn-home').addEventListener('click', (e) => { e.preventDefault(); this.showView('home'); });
                document.getElementById('nav-btn-releve').addEventListener('click', (e) => { e.preventDefault(); this.showView('releve'); });

                // Initial Render
                this.renderCharts();
            },

            showView: function(viewName) {
                const homeView = document.getElementById('view-home');
                const releveView = document.getElementById('view-releve');

                if (viewName === 'home') {
                    homeView.classList.remove('hidden');
                    releveView.classList.add('hidden');
                    // Reset grid on main by just showing the home view which has the grid
                } else {
                    homeView.classList.add('hidden');
                    releveView.classList.remove('hidden');
                }
            },

            saveReading: function() {
                const date = document.getElementById('input-date').value;
                const ph = parseFloat(document.getElementById('input-ph').value);
                const temp = parseFloat(document.getElementById('input-temp').value);

                if (date && !isNaN(ph) && !isNaN(temp)) {
                    this.data.readings.push({ date, ph, temp });
                    // Sort by date
                    this.data.readings.sort((a, b) => new Date(a.date) - new Date(b.date));
                    
                    localStorage.setItem('fishManagerData', JSON.stringify(this.data.readings));
                    
                    // Reset inputs
                    document.getElementById('input-ph').value = '';
                    document.getElementById('input-temp').value = '';
                    alert('Relevé enregistré !');
                }
            },

            switchTab: function(tab) {
                // Update Tab Styles
                ['durete', 'ph', 'temp'].forEach(t => {
                    const el = document.getElementById('tab-' + t);
                    if (t === tab) {
                        el.classList.remove('bg-white', 'text-brand-orange');
                        el.classList.add('bg-brand-orange', 'text-white'); // Active state (conceptually, though HTML structure makes it tricky to swap fully, we'll simplify)
                        
                        // Actually, the original design has fixed colors. 
                        // Let's just update the content area.
                    } 
                    // Note: The original CSS relies on specific classes for the active tab (white bg, colored text). 
                    // Non-active are colored bg, white text.
                    if (t === tab) {
                       el.className = "bg-white px-4 py-2 rounded-t-lg text-brand-orange font-bold text-sm border-t border-l border-r border-gray-200 flex items-center gap-2 cursor-pointer transition-colors";
                    } else {
                       el.className = "px-4 py-2 text-white font-medium text-sm bg-brand-orange hover:bg-orange-600 cursor-pointer rounded-t-lg flex items-center gap-2 transition-colors";
                    }
                });

                // Toggle Chart Visibility
                document.getElementById('waterChart').style.display = (tab === 'durete') ? 'block' : 'none';
                document.getElementById('chart-ph').classList.toggle('hidden', tab !== 'ph');
                document.getElementById('chart-temp').classList.toggle('hidden', tab !== 'temp');

                // Update Legend
                const legend = document.getElementById('chart-legend');
                if (tab === 'durete') {
                    legend.innerHTML = `
                        <div class="flex items-center gap-1"><span class="w-4 h-1 bg-green-500 rounded-full"></span> GH</div>
                        <div class="flex items-center gap-1"><span class="w-4 h-1 bg-orange-500 rounded-full"></span> KH</div>
                    `;
                } else if (tab === 'ph') {
                    legend.innerHTML = `
                        <div class="flex items-center gap-1"><span class="w-4 h-1 bg-red-500 rounded-full"></span> pH</div>
                    `;
                    this.drawD3Chart('chart-ph', 'ph', '#ef4444');
                } else if (tab === 'temp') {
                    legend.innerHTML = `
                        <div class="flex items-center gap-1"><span class="w-4 h-1 bg-orange-500 rounded-full"></span> Température (°C)</div>
                    `;
                    this.drawD3Chart('chart-temp', 'temp', '#f97316');
                }
            },

            drawD3Chart: function(containerId, metric, color) {
                const container = document.getElementById(containerId);
                container.innerHTML = ''; // Clear previous

                const width = container.clientWidth;
                const height = container.clientHeight;
                const margin = {top: 20, right: 20, bottom: 30, left: 40};

                const svg = d3.select("#" + containerId)
                    .append("svg")
                    .attr("width", width)
                    .attr("height", height)
                    .append("g")
                    .attr("transform", `translate(${margin.left},${margin.top})`);

                const chartWidth = width - margin.left - margin.right;
                const chartHeight = height - margin.top - margin.bottom;

                // Parse dates
                const parseDate = d3.timeParse("%Y-%m-%d");
                const data = this.data.readings.map(d => ({
                    date: parseDate(d.date),
                    value: d[metric]
                }));

                // Scales
                const x = d3.scaleTime()
                    .domain(d3.extent(data, d => d.date))
                    .range([0, chartWidth]);

                const y = d3.scaleLinear()
                    .domain([
                        d3.min(data, d => d.value) * 0.9, 
                        d3.max(data, d => d.value) * 1.1
                    ])
                    .range([chartHeight, 0]);

                // --- NEW: Threshold Zones ---
                let zones = [];
                if (metric === 'temp') {
                     zones = [
                        { min: -Infinity, max: 22, color: 'rgba(239, 68, 68, 0.2)' }, // Red < 22
                        { min: 22, max: 24, color: 'rgba(234, 179, 8, 0.2)' },      // Yellow 22-24
                        { min: 24, max: 26, color: 'rgba(34, 197, 94, 0.2)' },      // Green 24-26
                        { min: 26, max: 28, color: 'rgba(234, 179, 8, 0.2)' },      // Yellow 26-28
                        { min: 28, max: Infinity, color: 'rgba(239, 68, 68, 0.2)' } // Red > 28
                     ];
                } else if (metric === 'ph') {
                     zones = [
                        { min: -Infinity, max: 6.0, color: 'rgba(239, 68, 68, 0.15)' },
                        { min: 6.0, max: 6.5, color: 'rgba(234, 179, 8, 0.15)' },
                        { min: 6.5, max: 7.5, color: 'rgba(34, 197, 94, 0.15)' },
                        { min: 7.5, max: 8.0, color: 'rgba(234, 179, 8, 0.15)' },
                        { min: 8.0, max: Infinity, color: 'rgba(239, 68, 68, 0.15)' }
                     ];
                }

                // Add zones to background
                zones.forEach(z => {
                    const yDomain = y.domain();
                    const minVal = Math.max(z.min, yDomain[0]);
                    const maxVal = Math.min(z.max, yDomain[1]);
                    
                    if (minVal < maxVal) {
                        svg.append("rect")
                            .attr("x", 0)
                            .attr("width", chartWidth)
                            .attr("y", y(maxVal))
                            .attr("height", y(minVal) - y(maxVal))
                            .attr("fill", z.color)
                            .style("pointer-events", "none");
                    }
                });
                // -----------------------------

                // Axes
                svg.append("g")
                    .attr("transform", `translate(0,${chartHeight})`)
                    .call(d3.axisBottom(x).ticks(5).tickFormat(d3.timeFormat("%d/%m")))
                    .attr("color", "#9ca3af");

                svg.append("g")
                    .call(d3.axisLeft(y).ticks(5))
                    .attr("color", "#9ca3af");

                // Line
                const line = d3.line()
                    .x(d => x(d.date))
                    .y(d => y(d.value))
                    .curve(d3.curveMonotoneX);

                svg.append("path")
                    .datum(data)
                    .attr("fill", "none")
                    .attr("stroke", color)
                    .attr("stroke-width", 3)
                    .attr("d", line);

                // Dots
                svg.selectAll(".dot")
                    .data(data)
                    .enter().append("circle")
                    .attr("class", "dot")
                    .attr("cx", d => x(d.date))
                    .attr("cy", d => y(d.value))
                    .attr("r", 5)
                    .attr("fill", "white")
                    .attr("stroke", color)
                    .attr("stroke-width", 2);
            },
            
            renderCharts: function() {
                // Re-init existing Chart.js for Dureté (static for now as per user request to only touch Relevé parts, 
                // but we need to make sure it still works)
                // We destroyed the ctx reference by replacing the script, so we need to rebuild it if we want it to work.
                // However, the 'waterChart' canvas is still there. 
                // We'll just re-instantiate it here.
                const ctx = document.getElementById('waterChart').getContext('2d');
                if (window.myWaterChart) window.myWaterChart.destroy();
                
                window.myWaterChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: ['1', '5', '10', '15', '20', '25', '30'],
                        datasets: [
                            { label: 'GH', data: [5, 7, 8, 9, 10, 11, 12], borderColor: '#4ade80', backgroundColor: '#4ade80', tension: 0, pointRadius: 4, pointBackgroundColor: 'white', pointBorderWidth: 2 },
                            { label: 'KH', data: [2, 3, 5, 7, 6, 5, 6], borderColor: '#f97316', backgroundColor: '#f97316', tension: 0, pointRadius: 4, pointBackgroundColor: 'white', pointBorderWidth: 2 },
                             { label: 'Autre', data: [1, 2, 3, 4, 3, 5, 7], borderColor: '#60a5fa', backgroundColor: '#60a5fa', tension: 0, pointRadius: 4, pointBackgroundColor: 'white', pointBorderWidth: 2 }
                        ]
                    },
                    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { display: false, beginAtZero: true }, x: { grid: { display: true, color: '#e5e7eb' } } } }
                });
            }
        };

        // Start App
        document.addEventListener('DOMContentLoaded', () => {
            app.init();
        });
    </script>

    <script>
        const container = document.getElementById('fish-container');

        function createFish() {
            const fish = document.createElement('div');
            fish.classList.add('fish');

            // 1. Position Verticale aléatoire (entre 5% et 95% de la hauteur)
            const topPosition = Math.random() * 90 + 5;
            fish.style.top = topPosition + '%';

            // 2. Taille aléatoire (effet de profondeur)
            const scale = Math.random() * 0.8 + 0.5; // Entre 0.5 et 1.3
            // fish.style.transform = `scale(${scale})`; // <-- SUPPRIMÉ car écrase la direction
            
            // 3. Vitesse (durée de traversée)
            const duration = (Math.random() * 10 + 15) / scale; 
            
            // 4. Direction (Gauche vers Droite OU Droite vers Gauche)
            const startRight = Math.random() > 0.5;
            
            if (startRight) {
                // Part de la droite, nage vers la gauche
                fish.style.left = '110%'; // Hors écran
                fish.classList.add('swim-left'); 
                fish.style.transform = `scale(${scale}) scaleX(1)`; // Normal (regarde à gauche)

                const animation = fish.animate([
                    { left: '110%' },
                    { left: '-10%' }
                ], {
                    duration: duration * 1000,
                    easing: 'linear',
                    iterations: 1
                });
                animation.onfinish = () => fish.remove();

            } else {
                // Part de la gauche, nage vers la droite
                fish.style.left = '-10%'; // Hors écran
                fish.classList.add('swim-right');
                fish.style.transform = `scale(${scale}) scaleX(-1)`; // Miroir (regarde à droite)
                
                const animation = fish.animate([
                    { left: '-10%' },
                    { left: '110%' }
                ], {
                    duration: duration * 1000,
                    easing: 'linear',
                    iterations: 1
                });
                animation.onfinish = () => fish.remove();
            }

            container.appendChild(fish);
        }

        // Créer un poisson toutes les X millisecondes
        setInterval(createFish, 2000);

        // Créer quelques poissons au démarrage pour ne pas attendre
        for(let i=0; i<5; i++) {
            setTimeout(createFish, i * 500); 
        }
    </script>
</body>
