    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'brand-orange': '#D95D39',
                        'brand-bg': '#003B73',
                    },
                    fontFamily: {
                        sans: ['Segoe UI', 'Roboto', 'Helvetica', 'Arial', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background: linear-gradient(135deg, #005aa7 0%, #002855 100%);
            height: 100vh;
            overflow: hidden;
            position: relative;
        }

        /* --- STYLE DES POISSONS --- */
        #fish-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none; /* Permet de cliquer à travers les poissons */
            z-index: 1; /* Niveau 1 : Au-dessus du fond */
            overflow: hidden;
        }

        .fish {
            position: absolute;
            width: 27px;
            height: 23px;
            background-image: url(data:image/png;base64,);
            /* Animation du sprite (nageoires qui bougent) */
            animation: swimSprite 0.8s steps(8) infinite; 
        }

        /* Animation des nageoires */
        @keyframes swimSprite {
            100% { background-position: 0px -184px; }
        }

        /* CORRECTION ICI : Inversion des transformations */
        .swim-left { transform: scaleX(-1); } /* Miroir : Poisson regarde à gauche */
        .swim-right { transform: scaleX(1); } /* Normal : Poisson regarde à droite */

    </style>
</head>
