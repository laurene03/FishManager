{% extends 'base.html.twig' %}

{% block title %}Nouveau Relevé - FishManager{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
{% endblock %}

{% block body %}

    <div class="form-card">
        <div class="form-header">
            <h1 class="form-title"><i class="fa-solid fa-flask"></i> Nouveau Relevé</h1>
            <p class="form-subtitle">Saisissez les paramètres de l'eau du jour.</p>
        </div>

        {% for message in app.flashes('success') %}
            <div class="success-message">
                {{ message }}
            </div>
        {% endfor %}

        {{ form_start(form, {'attr': {'id': 'releve-form', 'class': 'form-content'}}) }}

            <div class="form-group">
                {{ form_label(form.date, 'Date', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.date, {'attr': {'class': 'form-input'}}) }}
                {{ form_errors(form.date, {'attr': {'class': 'form-error'}}) }}
            </div>

            <div class="form-group">
                {{ form_label(form.binome, 'Binôme', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.binome, {'attr': {'class': 'form-input'}}) }}
                {{ form_errors(form.binome, {'attr': {'class': 'form-error'}}) }}
            </div>

            <div class="form-grid">
                <div class="form-group">
                    {{ form_label(form.temperature, 'Température (°C)', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.temperature, {'attr': {'class': 'form-input'}}) }}
                    {{ form_errors(form.temperature, {'attr': {'class': 'form-error'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.CO2dissous, 'CO2 Dissous', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.CO2dissous, {'attr': {'class': 'form-input'}}) }}
                    {{ form_errors(form.CO2dissous, {'attr': {'class': 'form-error'}}) }}
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    {{ form_label(form.gH, 'gH', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.gH, {'attr': {'class': 'form-input'}}) }}
                    {{ form_errors(form.gH, {'attr': {'class': 'form-error'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.kH, 'kH', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.kH, {'attr': {'class': 'form-input'}}) }}
                    {{ form_errors(form.kH, {'attr': {'class': 'form-error'}}) }}
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    {{ form_label(form.chlore, 'Chlore', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.chlore, {'attr': {'class': 'form-input'}}) }}
                    {{ form_errors(form.chlore, {'attr': {'class': 'form-error'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.nitrite, 'Nitrite', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.nitrite, {'attr': {'class': 'form-input'}}) }}
                    {{ form_errors(form.nitrite, {'attr': {'class': 'form-error'}}) }}
                </div>
            </div>

            <div class="form-grid">
                <div class="form-group">
                    {{ form_label(form.nitrate, 'Nitrate', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.nitrate, {'attr': {'class': 'form-input'}}) }}
                    {{ form_errors(form.nitrate, {'attr': {'class': 'form-error'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.pH4, 'pH (Acidité)', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.pH4, {'attr': {'class': 'form-input'}}) }}
                    {{ form_errors(form.pH4, {'attr': {'class': 'form-error'}}) }}
                </div>
            </div>

            

            <div class="form-group">
                {{ form_label(form.remarque, 'Remarques (optionnel)', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.remarque, {'attr': {'class': 'form-input form-textarea'}}) }}
                {{ form_errors(form.remarque, {'attr': {'class': 'form-error'}}) }}
            </div>

            <div class="hidden">
                {{ form_rest(form) }}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">
                    <i class="fa-solid fa-save mr-2"></i>Enregistrer le relevé
                </button>
                <a href="{{ path('homepage') }}" class="btn-back">Retour</a>
            </div>
        {{ form_end(form) }}
    </div>

{% endblock %}
