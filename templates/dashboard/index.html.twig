{% extends 'base.html.twig' %}

{% block title %}FishManager{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
{% endblock %}
{% block javascripts %}
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'brand-orange': '#D95D39',
                        'brand-bg': '#003B73',
                    },
                    fontFamily: {
                        sans: ['Segoe UI', 'Roboto', 'Helvetica', 'Arial', 'sans-serif'],
                    }
                }
            }
        }
    </script>
{% endblock %}






{% block body %}

<div id="fish-container"></div>

    <div class="dashboard-card">
        <div class="dashboard-content">
            <div class="header-row">
                <div>
                    <h1 class="title">Bonjour User</h1>
                    <p class="subtitle">Suivi des paramètres de votre aquarium</p>
                </div>
                <div class="profile-section">
                    <a href="/profile" class="profile-btn" title="Profil">
                        <i class="fas fa-user"></i>
                    </a>
                </div>
            </div>

            <div class="filters-row">
                <div class="filter-pill">Durée</div>
                <div class="filter-pill">pH</div>
                <div class="filter-pill">Temp.</div>
                <div class="filter-pill">CO2</div>
                <div class="filter-pill">Azote</div>
            </div>

            <div class="chart-row">
                <div class="chart-card">
                    <twig:GraphComponent />     
                </div>
                <div class="period-selector">
                    <label for="period" class="sr-only">Période</label>
                    <select id="period" class="select-period">
                        <option>Ce mois</option>
                        <option>Ce trimestre</option>
                        <option>Cette année</option>
                    </select>
                </div>
            </div>

            <div class="action-row">
                <a href="/releve" class="btn-add">Ajouter un relevé</a>
            </div>
        </div>
    </div>


{% endblock %}

{% block jsbottom %}
    <script>
        const container = document.getElementById('fish-container');

        function createFish() {
            const fish = document.createElement('div');
            fish.classList.add('fish');

            // 1. Position Verticale aléatoire (entre 5% et 95% de la hauteur)
            const topPosition = Math.random() * 90 + 5;
            fish.style.top = topPosition + '%';

            // 2. Taille aléatoire (effet de profondeur)
            const scale = Math.random() * 0.8 + 0.5; // Entre 0.5 et 1.3
            // fish.style.transform = `scale(${scale})`; // <-- SUPPRIMÉ car écrase la direction
            
            // 3. Vitesse (durée de traversée)
            const duration = (Math.random() * 10 + 15) / scale; 
            
            // 4. Direction (Gauche vers Droite OU Droite vers Gauche)
            const startRight = Math.random() > 0.5;
            
            if (startRight) {
                // Part de la droite, nage vers la gauche
                fish.style.left = '110%'; // Hors écran
                fish.classList.add('swim-left'); 
                fish.style.transform = `scale(${scale}) scaleX(1)`; // Normal (regarde à gauche)

                const animation = fish.animate([
                    { left: '110%' },
                    { left: '-10%' }
                ], {
                    duration: duration * 1000,
                    easing: 'linear',
                    iterations: 1
                });
                animation.onfinish = () => fish.remove();

            } else {
                // Part de la gauche, nage vers la droite
                fish.style.left = '-10%'; // Hors écran
                fish.classList.add('swim-right');
                fish.style.transform = `scale(${scale}) scaleX(-1)`; // Miroir (regarde à droite)
                
                const animation = fish.animate([
                    { left: '-10%' },
                    { left: '110%' }
                ], {
                    duration: duration * 1000,
                    easing: 'linear',
                    iterations: 1
                });
                animation.onfinish = () => fish.remove();
            }

            container.appendChild(fish);
        }

        // Créer un poisson toutes les X millisecondes
        setInterval(createFish, 2000);

        // Créer quelques poissons au démarrage pour ne pas attendre
        for(let i=0; i<5; i++) {
            setTimeout(createFish, i * 500); 
        }
    </script>
{% endblock %}
