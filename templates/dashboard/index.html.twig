{% block jsbottom %}
    <script>
        const container = document.getElementById('fish-container');

        function createFish() {
            const fish = document.createElement('div');
            fish.classList.add('fish');

            // 1. Position Verticale aléatoire (entre 5% et 95% de la hauteur)
            const topPosition = Math.random() * 90 + 5;
            fish.style.top = topPosition + '%';

            // 2. Taille aléatoire (effet de profondeur)
            const scale = Math.random() * 0.8 + 0.5; // Entre 0.5 et 1.3
            // fish.style.transform = `scale(${scale})`; // <-- SUPPRIMÉ car écrase la direction
            
            // 3. Vitesse (durée de traversée)
            const duration = (Math.random() * 10 + 15) / scale; 
            
            // 4. Direction (Gauche vers Droite OU Droite vers Gauche)
            const startRight = Math.random() > 0.5;
            
            if (startRight) {
                // Part de la droite, nage vers la gauche
                fish.style.left = '110%'; // Hors écran
                fish.classList.add('swim-left'); 
                fish.style.transform = `scale(${scale}) scaleX(1)`; // Normal (regarde à gauche)

                const animation = fish.animate([
                    { left: '110%' },
                    { left: '-10%' }
                ], {
                    duration: duration * 1000,
                    easing: 'linear',
                    iterations: 1
                });
                animation.onfinish = () => fish.remove();

            } else {
                // Part de la gauche, nage vers la droite
                fish.style.left = '-10%'; // Hors écran
                fish.classList.add('swim-right');
                fish.style.transform = `scale(${scale}) scaleX(-1)`; // Miroir (regarde à droite)
                
                const animation = fish.animate([
                    { left: '-10%' },
                    { left: '110%' }
                ], {
                    duration: duration * 1000,
                    easing: 'linear',
                    iterations: 1
                });
                animation.onfinish = () => fish.remove();
            }

            container.appendChild(fish);
        }

        // Créer un poisson toutes les X millisecondes
        setInterval(createFish, 2000);

        // Créer quelques poissons au démarrage pour ne pas attendre
        for(let i=0; i<5; i++) {
            setTimeout(createFish, i * 500); 
        }
    </script>
{% endblock %}
